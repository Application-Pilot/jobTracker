# Copy to .env.local and fill in values to run with real AWS in dev.
# In production these are injected by the Terraform web module.

AWS_REGION=us-east-1
USERS_TABLE=jobtracker-dev-users
APP_URL=http://localhost:3001
TOKEN_KMS_KEY_ARN=arn:aws:kms:us-east-1:123456789012:key/replace-me
GMAIL_OAUTH_CLIENT_ID=1234567890-xxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GMAIL_OAUTH_CLIENT_SECRET=GOCSPX-replace-with-your-actual-secret
