{
  "name": "@jobtracker/web",
  "version": "0.0.0",
  "private": true,
  "description": "Jobtracker multi-tenant web app. Next.js 15 (App Router) deployed to AWS Lambda via OpenNext.",
  "scripts": {
    "dev": "next dev --port 3001",
    "build": "next build",
    "build:lambda": "open-next build",
    "package:lambda": "node ./scripts/package-for-terraform.mjs",
    "start": "next start --port 3001",
    "lint": "next lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/client-kms": "^3.1049.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "jose": "^5.9.0",
    "next": "^15.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@opennextjs/aws": "^3.4.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "typescript": "^5.5.0"
  }
}
