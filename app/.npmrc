# pnpm uses symlinked node_modules by default. That breaks OpenNext (and
# any other tool that walks node_modules expecting a flat layout) because
# the Lambda bundle can't follow symlinks back to a single store.
#
# `node-linker=hoisted` makes pnpm install dependencies as a flat
# node_modules tree, the way npm does. Slightly more disk, but
# OpenNext-compatible.
node-linker=hoisted
