# Root-level .gitignore for the jobtracker monorepo.
# Each subproject (prototype/, app/, infra/) has its own .gitignore for project-specific rules.

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp
*~

# Environment files (anywhere in the tree)
.env
.env.*
!.env.example

# Secrets — never commit credential files
cred.json
*service-account*.json
google-credentials*.json
credentials/
*.pem
*.key

# Logs (anywhere)
*.log

# Terraform (root-level safety net; infra/ has its own .gitignore too)
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform/
.terraform.lock.hcl
override.tf
override.tf.json
*_override.tf
*_override.tf.json
crash.log
crash.*.log

# Node / build output (safety net; subprojects manage their own)
node_modules/
.next/
out/
build/
dist/
*.tsbuildinfo
