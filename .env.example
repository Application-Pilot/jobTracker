# Spreadsheet ID (from the Sheet URL: docs.google.com/spreadsheets/d/<ID>/edit)
GOOGLE_SHEETS_ID=

# Service account email — share the Sheet with this address (Editor)
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Service account private key — paste the "private_key" value from the JSON,
# keeping it on one line with literal \n separators (or wrap in quotes with real newlines).
GOOGLE_SERVICE_ACCOUNT_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Gemini email extraction
GEMINI_API_KEY=

# Public base URL for local sync tools and manual testing.
# For deployed /api/sync, the server can fall back to the incoming request origin.
DASHBOARD_BASE_URL=http://localhost:3000

# Gmail OAuth credentials used by /api/sync and /api/bulk-sync.
GMAIL_REFRESH_TOKEN=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Optional: shared secret to authenticate Cloud Scheduler → /api/sync and
# sync worker → /api/applications/upsert calls.
SYNC_SHARED_SECRET=
